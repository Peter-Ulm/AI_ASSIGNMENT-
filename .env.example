# Copy this file to .env and adjust as needed. All values have safe defaults,
# so the app runs without a .env at all.

# ── LLM provider ────────────────────────────────────────────
# Only "ollama" is implemented; kept configurable for future providers.
LLM_PROVIDER=ollama

# ── Ollama (local model) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Change this one line to swap the model, e.g. llama3.2:1b or phi3.
OLLAMA_MODEL_NAME=llama3.2:3b
# Small model dedicated to embedding text for the RAG knowledge base.
EMBEDDING_MODEL_NAME=nomic-embed-text

# ── Generation ──────────────────────────────────────────────
DEFAULT_TEMPERATURE=0.7
REQUEST_TIMEOUT_SECONDS=120
MAX_QUESTION_CHARS=1000

# ── API server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── RAG ───────────────────────────────────────────────────────
# Whether the chat model is given the search_knowledge_base tool at all.
# Set to false to disable RAG entirely (plain chat, no tool).
USE_RAG=true

# ── Auth ──────────────────────────────────────────────────────
# Signs the login session token. Change this to a long random value for any
# real deployment - the default is only safe for local use.
JWT_SECRET=dev-secret-change-me
# How long a login session lasts before the user has to log in again.
JWT_EXPIRE_DAYS=7
# Must match where the frontend is actually served from - the auth cookie is
# only sent back by the browser if this origin matches exactly.
FRONTEND_ORIGIN=http://localhost:3000
# Cookies need HTTPS to set Secure. Keep false for local http; set true once
# the app is served over HTTPS.
COOKIE_SECURE=false

# ── Frontend ────────────────────────────────────────────────
# Used by the React frontend to reach the backend.
VITE_API_BASE_URL=http://localhost:8000
